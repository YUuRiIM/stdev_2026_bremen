{
  "name": "stdev-2026-bremen-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter @bremen/web dev",
    "build": "pnpm --filter @bremen/web build",
    "lint": "pnpm --filter @bremen/web lint",
    "agent:dev": "pnpm --filter @mys/agent dev",
    "agent:smoke": "cd apps/agent && SILERO_SKIP_LOAD=1 pnpm exec tsx src/smoke.ts",
    "shared:typecheck": "pnpm --filter @mys/shared typecheck",
    "shared:test": "pnpm --filter @mys/shared test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  }
}
