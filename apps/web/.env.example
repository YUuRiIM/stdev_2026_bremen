# apps/web/.env.example — copy to .env.local and fill in.
# Never commit .env.local (see /.gitignore).

# ═══ Supabase (stdev2026 project) ═══
NEXT_PUBLIC_SUPABASE_URL=https://putugflsowteaytsrvib.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<from Supabase Dashboard → Settings → API>

# ═══ Database (Drizzle CLI only) ═══
# Shared Pooler, Session mode (port 5432). Region: ap-northeast-1 (Tokyo).
# Get password from Supabase Dashboard → Settings → Database → Connection pooling.
DATABASE_URL=postgresql://postgres.putugflsowteaytsrvib:<PASSWORD>@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# ═══ LiveKit Cloud (voice rooms) ═══
LIVEKIT_URL=wss://<project>.livekit.cloud
LIVEKIT_API_KEY=<from LiveKit Cloud Dashboard>
LIVEKIT_API_SECRET=<from LiveKit Cloud Dashboard>

# ═══ Voice pipeline ═══
DEEPGRAM_API_KEY=<from console.deepgram.com>
ELEVENLABS_API_KEY=<from elevenlabs.io>
CHAR_DEFAULT_VOICE_ID=LTCsKRuKTT24n83eMvb9

# ═══ Gemini (shell env GEMINI_API_KEY auto-loaded if present) ═══
# JUDGE_GEMINI_API_KEY=<separate key for judge isolation, optional>

# ═══ Model IDs ═══
VOICE_LLM_MODEL=gemini-3-flash-preview
CHAT_TEXT_MODEL=gemini-3-flash-preview
JUDGE_MODEL=gemini-3-flash-preview

# ═══ Recall.ai (Google Meet bridge, Sprint 4) ═══
RECALL_API_KEY=<from recall.ai dashboard>

# ═══ App ═══
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DO NOT ADD:
# SUPABASE_SERVICE_ROLE_KEY (security invariant — agent uses JWT pass-through, web routes use anon/publishable)
